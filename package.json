    "monorepo",
    "cli",
    "ports",
    "orchestration",
    "parallel",
    "dev"
  ],
  "type": "module",
  "license": "MIT",
  "author": "hughcube",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hughcube/worktree-bay.git"
  },
  "bugs": {
    "url": "https://github.com/hughcube/worktree-bay/issues"
  },
  "homepage": "https://github.com/hughcube/worktree-bay#readme",
  "bin": {
